# FastAPI
APP_HOST=0.0.0.0
APP_PORT=8000
APP_ENV=production

# Authentication - For Ingest from Dispatcher
AI_INGEST_API_KEY=CHANGE_ME_DISPATCHER_KEY

# Authentication - For Web Backend
BACKEND_JWT_SECRET=CHANGE_ME_32_CHARS_MIN
BACKEND_SERVICE_TOKEN=CHANGE_ME
BACKEND_SERVER_URL=http://web-backend:8080

# PostgreSQL + pgvector
PG_HOST=localhost
PG_PORT=5432
PG_NAME=ai_server
PG_USER=ai_server
PG_PASSWORD=CHANGE_ME
PG_POOL_MIN=2
PG_POOL_MAX=10

# Anthropic API
ANTHROPIC_API_KEY=CHANGE_ME
ANTHROPIC_MODEL=claude-sonnet-4-6
ANTHROPIC_MAX_TOKENS=4096

# Embedding Model (Local sentence-transformers, CPU only)
EMBEDDING_MODEL=intfloat/multilingual-e5-small
EMBEDDING_DIMENSION=384
EMBEDDING_DEVICE=cpu
EMBEDDING_BATCH_SIZE=16
EMBEDDING_MAX_SEQ_LENGTH=512
EMBEDDING_USE_ONNX=true

# Scheduler
DAILY_REPORT_CRON=0 0 * * *
WEEKLY_REPORT_CRON=0 0 * * 1

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json
